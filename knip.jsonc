{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreExportsUsedInFile": {
    "interface": false,
    "type": false
  },
  "ignore": ["src/components/ui/**"],
  "drizzle": { "config": [] },
  "entry": [
    "src/app/**/*.{ts,tsx}",
    "src/entrypoints/**.ts",
    "drizzle.config.ts",
    "src/features/**/db.ts"
  ]
}
